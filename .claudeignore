# .claudeignore — файлы, которые Claude Code НЕ должен загружать в контекст.
# Экономия токенов 30-40% по замерам статьи vc.ru/ai/2868238.
#
# Правило: сюда включаем только то, что 100% не нужно для понимания кода.
# Если не уверены — не добавляйте.

# ═══ Python артефакты ════════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
build/
dist/

# ═══ Данные пользователя (БД, логи, аудио) ══════════════════════
data/db/
data/logs/
data/users/
*.db
*.db-journal
*.sqlite
*.sqlite3
*.log

# ═══ Аудио и медиа (большие бинарники) ══════════════════════════
*.mp3
*.wav
*.m4a
*.flac
*.ogg
*.mp4
*.webm

# ═══ Секреты и конфиги окружения ════════════════════════════════
.env
.env.*
*.secret
credentials.json

# ═══ Git и системные ════════════════════════════════════════════
.git/
.DS_Store
Thumbs.db
*.swp
*.swo

# ═══ IDE ════════════════════════════════════════════════════════
.vscode/
.idea/
*.iml

# ═══ Исторические документы (читать только при явном запросе) ═══
# Текущая архитектура — в AGENTS.md и memory/.
# Старые версии оставляем в репо, но не грузим в контекст.
ARCHITECTURE_v3.md
ARCHITECTURE_v4.md
STRATEGIC_PLAN_v4.md
DEVELOPMENT_PLAN.md
reference_batch_asr.py
процесс.txt
